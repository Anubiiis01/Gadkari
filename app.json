{
  "expo": {
    "name": "Gadkari",
    "slug": "Gadkari",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Gadkari to access your location to show nearby treks."
        }
      ]
    ],
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F77F00"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.Gadkari"
    },
    "android": {
      "package": "com.anonymous.Gadkari",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    }
  }
}